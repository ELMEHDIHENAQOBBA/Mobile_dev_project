# Frontend environment variables
# Copy this file to .env and fill in your values

# OpenRouter API key — get a free one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use — browse free models at https://openrouter.ai/models?q=free
AI_MODEL=stepfun/step-3.5-flash:free

# Backend URL — use localhost:8080/api for dev or your Render URL for production
BACKEND_URL=https://your-backend-on-render.onrender.com/api
